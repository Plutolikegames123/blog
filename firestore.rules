rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidBlog(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.profile is map &&
             data.settings is map &&
             data.isActive is bool &&
             (data.password == null || data.password is string);
    }

    match /blogs/{blogId} {
      // Allowing public access for now as the app doesn't have a login flow, 
      // but enforcing strict schema validation on writes.
      // Note: In a production app, you should restrict writes to authorized users.
      allow read: if true;
      allow create: if isValidId(blogId) && isValidBlog(incoming());
      allow update: if isValidBlog(incoming()) && incoming().updatedAt == request.time;
      allow delete: if false; // Disallow deletion from client for safety
    }
  }
}
