{
  "entities": {
    "Blog": {
      "title": "Blog",
      "description": "Data structure for a vibrant blog site",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the blog" },
        "password": { "type": "string", "description": "Password protection for the blog" },
        "impactTitle": { "type": "string", "description": "Title for the impact section" },
        "isActive": { "type": "boolean", "description": "Whether the blog is currently active" },
        "profile": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "bio": { "type": "string" },
            "profilePic": { "type": "string" },
            "coverPhoto": { "type": "string" },
            "socials": {
              "type": "object",
              "properties": {
                "facebook": { "type": "string" },
                "twitter": { "type": "string" },
                "instagram": { "type": "string" },
                "linkedin": { "type": "string" },
                "youtube": { "type": "string" }
              }
            }
          }
        },
        "infoSections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "contentBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "image", "video"] },
              "value": { "type": "string" }
            }
          }
        },
        "socialImpact": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["positive", "negative"] },
              "label": { "type": "string" },
              "value": { "type": "string" },
              "mediaType": { "type": "string", "enum": ["none", "image", "video"] },
              "mediaUrl": { "type": "string" }
            }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "typewriterWords": { "type": "array", "items": { "type": "string" } },
            "fontSize": { "type": "number" },
            "textColor": { "type": "string" },
            "bgColor": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "profile", "settings"]
    }
  },
  "firestore": {
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Individual blog site data"
    }
  }
}
